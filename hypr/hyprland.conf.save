monitr=,preferred,auto,auto

exec-once = waybar &
exec-once = kitty &

input {
 kb_layout = us
}

general {
   gaps_in = 5
   gaps_in = 10 
   border_size = 2
}

decoration {
   rounding = 5
} 

animations {
    enabled = yes

    bezier = smooth, 0.25, 0.1, 0.25, 1.0

    animation = windows, 1, 7, smooth
    animation = fade, 1, 7, smooth
    animation = workspaces, 1, 6, smooth
}

decoration {
    blur {
        enabled = true
        size = 8
        passes = 2
        new_optimizations = true
    }
}

exec-once = waybar
bind = SUPER, A, exec, wofi --show drun
bind = SUPER, T, exec, kitty
bind = SUPER, Q, killactive
bind = SUPER, M, exit
bind = SUPER, N, exec, mpc clear && mpc add / && mpc play
bind = SUPER, E, exec, dolphin
bind = SUPER, P, exec, flameshot gui
bind = SUPER, R, exec, wofi --show drun
bind = SUPER, B, exec, ~/Downloads/Helium.AppImage
bind = SUPER, O, exec, mpc play
bind = SUPER, X, exec, mpc stop
5bind = SUPER, SPACE, exec, mpc toggle
bind = SUPER, RIGHT, exec, mpc next
bind = SUPER, LEFT, exec, mpc prev
bind = SUPER, 1, workspace, 1
bind = SUPER, 2, workspace, 2
bind = SUPER, 3, workspace, 3
bind = SUPER, 4, workspace, 4
bind = SUPER, 5, workspace, 5
bind = SUPER, 6, workspace, 6
bind = SUPER, 7, workspace, 7
bind = SUPER, 8, workspace, 8
bind = SUPER, 9, workspace, 9
bind = SUPER, UP, exec, pactl set-sink-volume @DEFAULT_SINK@ +5%
bind = SUPER, DOWN, exec, pactl set-sink-volume @DEFAULT_SINK@ -5%

